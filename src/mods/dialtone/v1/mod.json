{
  "name": "dialtone",
  "version": "v1",
  "depends_on": [
    { "name": "shell", "version": "v1" }
  ],
  "env_vars": [
    { "name": "DIALTONE_REPO_ROOT", "required": true },
    { "name": "DIALTONE_STATE_DIR", "required": true },
    { "name": "DIALTONE_STATE_DB", "required": true },
    { "name": "DIALTONE_DAEMON_LOG_PATH", "required": false }
  ],
  "testing": {
    "requires_nix": false,
    "serial_group": "desktop",
    "visible_tmux": false
  }
}
