#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ARCH="$(uname -m)"
case "$ARCH" in
  x86_64|amd64) BIN="$SCRIPT_DIR/dialtone_swarm_v3_x86_64" ;;
  aarch64|arm64) BIN="$SCRIPT_DIR/dialtone_swarm_v3_arm64" ;;
  *) echo "error: unsupported architecture: $ARCH" >&2; exit 1 ;;
esac
exec "$BIN" "$@"
