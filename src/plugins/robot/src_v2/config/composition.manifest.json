{
  "name": "robot",
  "composition_version": "v1",
  "version": "src_v2",
  "runtime": {
    "binary": "<autoswap_root>/artifacts/dialtone_robot_v2",
    "http_listen": ":8080",
    "nats_listen": "nats://127.0.0.1:4222",
    "nats_ws_listen": "ws://127.0.0.1:4223",
    "processes": [
      {
        "name": "robot",
        "artifact": "robot",
        "args": [
          "--listen",
          "${listen}",
          "--nats-port",
          "${nats_port}",
          "--nats-ws-port",
          "${nats_ws_port}",
          "--ui-dist",
          "${artifact:ui_dist}"
        ],
        "env": {
          "ROBOT_V2_CAMERA_STREAM_URL": "http://127.0.0.1:19090",
          "ROBOT_V2_MAVLINK_ENABLED": "1"
        }
      },
      {
        "name": "camera",
        "artifact": "camera",
        "depends_on": ["robot"],
        "env": {
          "CAMERA_DEVICE": "/dev/video1"
        },
        "args": [
          "run",
          "--nats-url",
          "${nats_url}",
          "--subject",
          "camera.heartbeat",
          "--interval",
          "250ms",
          "--listen",
          ":19090",
          "--serve-stream=true"
        ]
      },
      {
        "name": "mavlink",
        "artifact": "mavlink",
        "depends_on": ["robot"],
        "args": [
          "run",
          "--nats-url",
          "${nats_url}",
          "--mock-if-no-endpoint=false"
        ],
        "env": {
          "MAVLINK_ENDPOINT": "serial:/dev/ttyAMA0:57600"
        }
      },
      {
        "name": "repl",
        "artifact": "repl",
        "depends_on": ["robot"],
        "args": [
          "leader",
          "--nats-url",
          "${nats_url}",
          "--room",
          "robot",
          "--embedded-nats=false",
          "--hostname",
          "robot-v2"
        ]
      }
    ]
  },
  "artifacts": {
    "sync": {
      "autoswap": "<autoswap_root>/artifacts/dialtone_autoswap_v1",
      "robot": "<autoswap_root>/artifacts/dialtone_robot_v2",
      "repl": "<autoswap_root>/artifacts/dialtone_repl_v1",
      "camera": "<autoswap_root>/artifacts/dialtone_camera_v1",
      "mavlink": "<autoswap_root>/artifacts/dialtone_mavlink_v1",
      "wlan": "<autoswap_root>/wlan",
      "ui_dist": "<autoswap_root>/artifacts/robot_src_v2_ui_dist"
    },
    "release": {
      "autoswap": {
        "asset": "dialtone_autoswap-${goos}-${goarch}",
        "type": "file"
      },
      "robot": {
        "asset": "dialtone_robot_v2-${goos}-${goarch}",
        "type": "file"
      },
      "repl": {
        "asset": "dialtone_repl-${goos}-${goarch}",
        "type": "file"
      },
      "camera": {
        "asset": "dialtone_camera_v1-${goos}-${goarch}",
        "type": "file"
      },
      "mavlink": {
        "asset": "dialtone_mavlink_v1-${goos}-${goarch}",
        "type": "file"
      },
      "ui_dist": {
        "asset": "robot_src_v2_ui_dist-${goos}-${goarch}.tar.gz",
        "type": "dir",
        "extract": "tar.gz"
      }
    }
  },
  "capabilities": {
    "requires": ["natsws", "camera", "mavlink", "wlan"]
  }
}
