{
  "name": "robot",
  "version": "src_v2",
  "artifacts": {
    "sync": {
      "autoswap": "<repo_root>/bin/dialtone_autoswap_v1",
      "robot": "<repo_root>/bin/dialtone_robot_v2",
      "repl": "<repo_root>/bin/dialtone_repl_v1",
      "camera": "<repo_root>/bin/dialtone_camera_v1",
      "mavlink": "<repo_root>/bin/dialtone_mavlink_v1",
      "wlan": "<repo_root>/src/plugins/wlan/src_v1",
      "ui_dist": "<repo_root>/src/plugins/robot/src_v2/ui/dist"
    },
    "release": {
      "autoswap": {"asset": "dialtone_autoswap-${goos}-${goarch}", "type": "file"},
      "robot": {"asset": "dialtone_robot_v2-${goos}-${goarch}", "type": "file"},
      "repl": {"asset": "dialtone_repl-${goos}-${goarch}", "type": "file"},
      "camera": {"asset": "dialtone_camera_v1-${goos}-${goarch}", "type": "file"},
      "mavlink": {"asset": "dialtone_mavlink_v1-${goos}-${goarch}", "type": "file"},
      "ui_dist": {"asset": "robot_src_v2_ui_dist-${goos}-${goarch}.tar.gz", "type": "dir", "extract": "tar.gz"}
    }
  },
  "http": {
    "listen": ":8080",
    "routes": ["/", "/health", "/api/init", "/stream", "/natsws"]
  }
}
