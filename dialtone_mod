FAST_STATUS_ROW_ID=""
FAST_STATUS_FULL=0

parse_fast_shell_status_args() {
  FAST_STATUS_ROW_ID=""
  FAST_STATUS_FULL=0
  while [ "$#" -gt 0 ]; do
    case "${1:-}" in
      --row-id)
        [ "$#" -ge 2 ] || return 1
        FAST_STATUS_ROW_ID="$(trim_text "${2:-}")"
        shift 2
        ;;
      --row-id=*)
        FAST_STATUS_ROW_ID="$(trim_text "${1#*=}")"
        shift
        ;;
      --full|--full=true)
        FAST_STATUS_FULL=1
        shift
        ;;
      --full=false)
        FAST_STATUS_FULL=0
        shift
        ;;
      --sync)
        if [ "$#" -ge 2 ] && [[ "${2:-}" != -* ]]; then
          shift 2
        else
          shift
        fi
        ;;
      --sync=*)
        shift
        ;;
      --limit)
        [ "$#" -ge 2 ] || return 1
        shift 2
        ;;
      --limit=*)
        shift
        ;;
      *)
        return 1
        ;;
    esac
  done
  if [ -n "$FAST_STATUS_ROW_ID" ] && ! [[ "$FAST_STATUS_ROW_ID" =~ ^[0-9]+$ ]]; then
    return 1
  fi
  return 0
}

sqlite_scalar() {
  local query="${1:-}"
  local value=""
  if [ -z "$query" ] || [ ! -f "$DIALTONE_STATE_DB" ]; then
    return 0
  fi
  value="$(run_sqlite_query "$DIALTONE_STATE_DB" "$query" 2>/dev/null || true)"
  printf '%s' "$(trim_text "$value")"
}

latest_snapshot_summary_fast() {
  local pane="${1:-}"
  if [ -z "$pane" ]; then
    return 0
  fi
  sqlite_scalar "
select coalesce(trim(json_extract(body_json, '$.summary')), '')
from shell_bus
where scope = 'observed'
  and subject = 'pane'
  and action = 'snapshot'
  and trim(pane) = '$(sql_quote "$pane")'
order by id desc
limit 1;
"
}

latest_snapshot_text_fast() {
  local pane="${1:-}"
  if [ -z "$pane" ]; then
    return 0
  fi
  if [ ! -f "$DIALTONE_STATE_DB" ]; then
    return 0
  fi
  run_sqlite_query "$DIALTONE_STATE_DB" "
select coalesce(json_extract(body_json, '$.text'), '')
from shell_bus
where scope = 'observed'
  and subject = 'pane'
  and action = 'snapshot'
  and trim(pane) = '$(sql_quote "$pane")'
order by id desc
limit 1;
" 2>/dev/null || true
}

print_fast_shell_command_status() {
  local row_id="${1:-}"
  local full="${2:-0}"
  local status=""
  local command=""
  local target=""
  local started_at=""
  local finished_at=""
  local pid=""
  local exit_code=""
  local runtime_ms=""
  local summary=""
  local error_text=""
  local output_text=""

  if [ -z "$row_id" ] || ! [[ "$row_id" =~ ^[0-9]+$ ]]; then
    return 0
  fi
  status="$(sqlite_scalar "select coalesce(trim(status), '') from shell_bus where id = $row_id limit 1;")"
  [ -n "$status" ] || return 0
  command="$(sqlite_scalar "select coalesce(nullif(trim(json_extract(body_json, '$.display_command')), ''), nullif(trim(json_extract(body_json, '$.inner_command')), ''), trim(json_extract(body_json, '$.command')), '') from shell_bus where id = $row_id limit 1;")"
  target="$(sqlite_scalar "select coalesce(nullif(trim(json_extract(body_json, '$.target')), ''), trim(pane), '') from shell_bus where id = $row_id limit 1;")"
  started_at="$(sqlite_scalar "select coalesce(trim(json_extract(body_json, '$.started_at')), '') from shell_bus where id = $row_id limit 1;")"
  finished_at="$(sqlite_scalar "select coalesce(trim(json_extract(body_json, '$.finished_at')), '') from shell_bus where id = $row_id limit 1;")"
  pid="$(sqlite_scalar "select coalesce(trim(json_extract(body_json, '$.pid')), '') from shell_bus where id = $row_id limit 1;")"
  exit_code="$(sqlite_scalar "select coalesce(trim(json_extract(body_json, '$.exit_code')), '') from shell_bus where id = $row_id limit 1;")"
  runtime_ms="$(sqlite_scalar "select coalesce(trim(json_extract(body_json, '$.runtime_ms')), '') from shell_bus where id = $row_id limit 1;")"
  summary="$(sqlite_scalar "select coalesce(trim(json_extract(body_json, '$.summary')), '') from shell_bus where id = $row_id limit 1;")"
  error_text="$(sqlite_scalar "select coalesce(trim(json_extract(body_json, '$.error')), '') from shell_bus where id = $row_id limit 1;")"
  if [ "$status" = "done" ] && [ -z "$exit_code" ]; then
    exit_code="0"
  fi

  printf 'command_row_id\t%s\n' "$row_id"
  printf 'command_status\t%s\n' "$status"
  if [ -n "$command" ]; then
    printf 'command\t%s\n' "$command"
    printf 'last_command\t%s\n' "$command"
  fi
  if [ -n "$target" ]; then
    printf 'command_target\t%s\n' "$target"
  fi
  if [ -n "$started_at" ]; then
    printf 'command_started_at\t%s\n' "$started_at"
  fi
  if [ -n "$finished_at" ]; then
    printf 'command_finished_at\t%s\n' "$finished_at"
  fi
  if [ -n "$pid" ] && [ "$pid" != "0" ]; then
    printf 'command_pid\t%s\n' "$pid"
  else
    printf 'command_pid\tpending\n'
  fi
  if [ -n "$exit_code" ] && { [ "$status" = "done" ] || [ "$status" = "failed" ] || [ "$exit_code" != "0" ]; }; then
    printf 'command_exit_code\t%s\n' "$exit_code"
  else
    printf 'command_exit_code\tpending\n'
  fi
  if [ "$status" = "done" ] && [ -z "$runtime_ms" ]; then
    runtime_ms="0"
  fi
  if [ -n "$runtime_ms" ]; then
    printf 'command_runtime_ms\t%s\n' "$runtime_ms"
  else
    printf 'command_runtime_ms\tpending\n'
  fi
  if [ -n "$summary" ]; then
    printf 'command_summary\t%s\n' "$summary"
  fi
  if [ -n "$error_text" ]; then
    printf 'command_error\t%s\n' "$error_text"
  fi
  if [ "$full" = "1" ]; then
    output_text="$(run_sqlite_query "$DIALTONE_STATE_DB" "select coalesce(json_extract(body_json, '$.output'), '') from shell_bus where id = $row_id limit 1;" 2>/dev/null || true)"
    if [ -n "$(trim_text "$output_text")" ]; then
      printf 'command_output\n%s\n' "$output_text"
      printf 'last_command_output\n%s\n' "$output_text"
    fi
  fi
}

