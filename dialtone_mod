#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${DIALTONE_REPO_ROOT:-$SCRIPT_DIR}"
USE_NIX="${DIALTONE_USE_NIX:-1}"
DIALTONE_HOME_ROOT="${HOME:-$SCRIPT_DIR}"
DIALTONE_STATE_DIR="${DIALTONE_STATE_DIR:-$DIALTONE_HOME_ROOT/.dialtone}"
DIALTONE_STATE_DB="${DIALTONE_STATE_DB:-$DIALTONE_STATE_DIR/state.sqlite}"
DIALTONE_TMUX_TARGET_FILE="${DIALTONE_TMUX_TARGET_FILE:-$DIALTONE_STATE_DIR/tmux_target}"
declare -a DIALTONE_NIX_PACKAGES=()

mkdir -p "$DIALTONE_STATE_DIR"

rewrite_nix_package_ref() {
  local pkg="${1:-}"
  if [[ "$pkg" == nixpkgs#* ]] && [ "$NIXPKGS_FLAKE_REF" != "nixpkgs" ]; then
    printf '%s#%s' "$NIXPKGS_FLAKE_REF" "${pkg#nixpkgs#}"
    return
  fi
  printf '%s' "$pkg"
}

shell_quote() {
  printf "%q" "${1:-}"
}

join_shell_args() {
  local out=""
  local arg=""
  for arg in "$@"; do
    if [ -n "$out" ]; then
      out+=" "
    fi
    out+="$(shell_quote "$arg")"
  done
  printf '%s' "$out"
}

build_dialtone_command() {
  local quoted_args=""
  quoted_args="$(join_shell_args "$@")"
  if [ -n "$quoted_args" ]; then
    printf './dialtone_mod %s' "$quoted_args"
    return
  fi
  printf './dialtone_mod'
}

sql_quote() {
  printf '%s' "${1:-}" | sed "s/'/''/g"
}

trim_text() {
  printf '%s' "${1:-}" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//'
}

now_utc_rfc3339() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

hydrate_env_from_state_db() {
  local key=""
  local value=""

  if [ ! -f "$DIALTONE_STATE_DB" ]; then
    return 0
  fi

  while IFS=$'\t' read -r key value; do
    if [ -z "$key" ]; then
      continue
    fi
    case "$key" in
      DIALTONE_TMUX_PROXY_ACTIVE|DIALTONE_TMUX_TARGET|DIALTONE_TMUX_TARGET_FILE|DIALTONE_NIX_ACTIVE|DIALTONE_NIX_BASE_PATH|DIALTONE_NIX_PACKAGES_SIG|DIALTONE_NIX_SHELL)
        continue
        ;;
    esac
    if [[ "$key" != DIALTONE_* ]] && [ "$key" != "NIXPKGS_FLAKE" ]; then
      continue
    fi
    if [ -n "${!key:-}" ]; then
      continue
    fi
    export "$key=$value"
  done < <(
    run_sqlite_query "$DIALTONE_STATE_DB" \
      "select key, value from runtime_env where scope = 'process' and (key like 'DIALTONE_%' or key = 'NIXPKGS_FLAKE') order by key;" \
      2>/dev/null || true
  )
}

run_sqlite_query() {
  local db_path="${1:-}"
  local query="${2:-}"
  local flake_ref="${DIALTONE_NIXPKGS_FLAKE:-${NIXPKGS_FLAKE:-nixpkgs}}"
  local nix_args=()

  if [ -z "$db_path" ] || [ -z "$query" ] || [ ! -f "$db_path" ]; then
    return 1
  fi
  if command -v sqlite3 >/dev/null 2>&1; then
    sqlite3 -cmd ".timeout 5000" -tabs -noheader "$db_path" "$query"
    return
  fi
  if ! command -v nix >/dev/null 2>&1; then
    return 1
  fi
  if [ "${DIALTONE_NIX_OFFLINE:-0}" = "1" ]; then
    nix_args+=(--offline)
  fi
  nix \
    "${nix_args[@]}" \
    --extra-experimental-features "nix-command flakes" \
    shell "${flake_ref}#sqlite" \
    --command sqlite3 -cmd ".timeout 5000" -tabs -noheader "$db_path" "$query"
}

run_sqlite_exec() {
  local db_path="${1:-}"
  local query="${2:-}"
  run_sqlite_query "$db_path" "$query" >/dev/null
}

run_sqlite_script() {
  local db_path="${1:-}"
  local flake_ref="${DIALTONE_NIXPKGS_FLAKE:-${NIXPKGS_FLAKE:-nixpkgs}}"
  local nix_args=()

  if [ -z "$db_path" ]; then
    return 1
  fi
  mkdir -p "$(dirname "$db_path")"
  if command -v sqlite3 >/dev/null 2>&1; then
    sqlite3 -cmd ".timeout 5000" -tabs -noheader "$db_path"
    return
  fi
  if ! command -v nix >/dev/null 2>&1; then
    return 1
  fi
  if [ "${DIALTONE_NIX_OFFLINE:-0}" = "1" ]; then
    nix_args+=(--offline)
  fi
  nix \
    "${nix_args[@]}" \
    --extra-experimental-features "nix-command flakes" \
    shell "${flake_ref}#sqlite" \
    --command sqlite3 -cmd ".timeout 5000" -tabs -noheader "$db_path"
}

ensure_fast_route_schema() {
  run_sqlite_script "$DIALTONE_STATE_DB" <<'SQL' >/dev/null
PRAGMA journal_mode=WAL;
PRAGMA foreign_keys=ON;
PRAGMA busy_timeout=1000;
create table if not exists state_values (
  scope text not null,
  key text not null,
  value text not null,
  updated_at text not null,
  primary key (scope, key)
);
create table if not exists shell_bus (
  id integer primary key autoincrement,
  system text not null,
  scope text not null,
  subject text not null,
  action text not null,
  status text not null,
  actor text not null,
  session text not null default '',
  pane text not null default '',
  ref_id integer not null default 0,
  body_json text not null default '',
  created_at text not null,
  updated_at text not null
);
SQL
}

load_state_value() {
  local key="${1:-}"
  local raw=""
  if [ -z "$key" ] || [ ! -f "$DIALTONE_STATE_DB" ]; then
    return 0
  fi
  raw="$(run_sqlite_query "$DIALTONE_STATE_DB" "select value from state_values where scope = 'system' and key = '$(sql_quote "$key")' limit 1;" 2>/dev/null || true)"
  raw="$(printf '%s' "$raw" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
  printf '%s' "$raw"
}

upsert_state_value() {
  local key="${1:-}"
  local value="${2:-}"
  local now=""
  if [ -z "$key" ]; then
    return 1
  fi
  ensure_fast_route_schema
  now="$(now_utc_rfc3339)"
  run_sqlite_exec "$DIALTONE_STATE_DB" "
insert into state_values(scope, key, value, updated_at)
values('system', '$(sql_quote "$key")', '$(sql_quote "$value")', '$(sql_quote "$now")')
on conflict(scope, key) do update set
  value = excluded.value,
  updated_at = excluded.updated_at;
"
}

clear_state_value() {
  local key="${1:-}"
  if [ -z "$key" ] || [ ! -f "$DIALTONE_STATE_DB" ]; then
    return 0
  fi
  run_sqlite_exec "$DIALTONE_STATE_DB" "
delete from state_values
where scope = 'system'
  and key = '$(sql_quote "$key")';
"
}

ensure_bootstrap_state() {
  local bootstrap_status=""
  local bootstrap_log=""
  local bootstrap_time=""
  local log_dir=""

  bootstrap_status="$(load_state_value "bootstrap.status")"
  if [ "$bootstrap_status" = "ready" ]; then
    return 0
  fi

  ensure_fast_route_schema
  log_dir="$DIALTONE_STATE_DIR/logs"
  mkdir -p "$log_dir"
  bootstrap_time="$(now_utc_rfc3339)"
  bootstrap_log="$log_dir/bootstrap-$(date -u +%s)-$$.log"
  {
    printf 'dialtone bootstrap (simulated)\n'
    printf 'completed_at=%s\n' "$bootstrap_time"
    printf 'repo_root=%s\n' "$REPO_ROOT"
    printf 'default_shell=default\n'
    printf 'sqlite_runtime=nix-managed\n'
    printf 'worker_runtime=nix-managed\n'
    printf 'notes=First-run bootstrap would prefetch the default dev shell and sqlite runtime here.\n'
  } >"$bootstrap_log"

  upsert_state_value "bootstrap.status" "ready" >/dev/null
  upsert_state_value "bootstrap.mode" "simulated" >/dev/null
  upsert_state_value "bootstrap.shell" "default" >/dev/null
  upsert_state_value "bootstrap.sqlite_runtime" "nix-managed" >/dev/null
  upsert_state_value "bootstrap.worker_runtime" "nix-managed" >/dev/null
  upsert_state_value "bootstrap.log_path" "$bootstrap_log" >/dev/null
  upsert_state_value "bootstrap.completed_at" "$bootstrap_time" >/dev/null
}

exec_dialtone_internal() {
  exec "$REPO_ROOT/dialtone_mod" __dialtone "$@"
}

dialtone_daemon_healthy() {
  local daemon_status=""
  local daemon_pid=""
  local daemon_heartbeat=""
  local now_epoch=0
  local heartbeat_epoch=0
  local age=0

  daemon_status="$(load_state_value "dialtone.daemon.status")"
  daemon_pid="$(load_state_value "dialtone.daemon.pid")"
  daemon_heartbeat="$(load_state_value "dialtone.daemon.heartbeat_at")"
  if [ "$daemon_status" != "running" ] || [ -z "$daemon_pid" ] || [ -z "$daemon_heartbeat" ]; then
    return 1
  fi
  if ! process_alive "$daemon_pid"; then
    return 1
  fi
  if ! heartbeat_epoch="$(rfc3339_to_epoch "$daemon_heartbeat")"; then
    return 1
  fi
  now_epoch="$(date -u +%s)"
  age=$((now_epoch - heartbeat_epoch))
  [ "$age" -le 10 ]
}

start_dialtone_daemon() {
  local pid=""
  local log_path=""
  local log_dir=""
  local started_at=""

  pid="$(load_state_value "dialtone.daemon.pid")"
  log_path="$(load_state_value "dialtone.daemon.log_path")"
  if dialtone_daemon_healthy; then
    printf '%s\t%s\t%s\n' "$pid" "$log_path" "running"
    return 0
  fi
  if process_alive "$pid"; then
    printf '%s\t%s\t%s\n' "$pid" "$log_path" "existing"
    return 0
  fi
  log_dir="$DIALTONE_STATE_DIR/logs"
  mkdir -p "$log_dir"
  log_path="$log_dir/dialtone-daemon-$(date -u +%s)-$$-${RANDOM:-0}.log"
  if command -v python3 >/dev/null 2>&1; then
    pid="$(
      python3 - "$log_path" "$REPO_ROOT/dialtone_mod" <<'PY'
import os
import sys

log_path = sys.argv[1]
script_path = sys.argv[2]

pid = os.fork()
if pid:
    print(pid)
    sys.exit(0)

os.setsid()
fd = os.open(log_path, os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o644)
devnull = os.open(os.devnull, os.O_RDONLY)
os.dup2(devnull, 0)
os.dup2(fd, 1)
os.dup2(fd, 2)
os.environ["DIALTONE_DAEMON_LOG_PATH"] = log_path
os.execv(script_path, [script_path, "__dialtone", "serve"])
PY
    )"
  else
    nohup env DIALTONE_DAEMON_LOG_PATH="$log_path" "$REPO_ROOT/dialtone_mod" __dialtone serve >"$log_path" 2>&1 </dev/null &
    pid="$!"
  fi
  pid="$(trim_text "$pid")"
  started_at="$(now_utc_rfc3339)"
  upsert_state_value "dialtone.daemon.pid" "$pid" >/dev/null
  upsert_state_value "dialtone.daemon.log_path" "$log_path" >/dev/null
  upsert_state_value "dialtone.daemon.status" "starting" >/dev/null
  upsert_state_value "dialtone.daemon.started_at" "$started_at" >/dev/null
  upsert_state_value "dialtone.daemon.heartbeat_at" "$started_at" >/dev/null
  printf '%s\t%s\t%s\n' "$pid" "$log_path" "started"
}

run_dialtone_serve() {
  local daemon_pid="$$"
  local daemon_log=""
  local now=""
  local existing_pid=""

  daemon_log="${DIALTONE_DAEMON_LOG_PATH:-}"
  if [ -z "$daemon_log" ]; then
    daemon_log="$(load_state_value "dialtone.daemon.log_path")"
  fi
  existing_pid="$(load_state_value "dialtone.daemon.pid")"
  if [ -n "$existing_pid" ] && [ "$existing_pid" != "$daemon_pid" ] && process_alive "$existing_pid"; then
    printf 'dialtone already running\t%s\n' "$existing_pid"
    return 0
  fi
  dialtone_mark_stopped() {
    now="$(now_utc_rfc3339)"
    upsert_state_value "dialtone.daemon.status" "stopped" >/dev/null || true
    upsert_state_value "dialtone.daemon.heartbeat_at" "$now" >/dev/null || true
  }
  trap 'dialtone_mark_stopped' EXIT
  trap 'dialtone_mark_stopped; exit 0' INT TERM
  while true; do
    now="$(now_utc_rfc3339)"
    upsert_state_value "dialtone.daemon.pid" "$daemon_pid" >/dev/null || true
    upsert_state_value "dialtone.daemon.status" "running" >/dev/null || true
    upsert_state_value "dialtone.daemon.heartbeat_at" "$now" >/dev/null || true
    if [ -n "$daemon_log" ]; then
      upsert_state_value "dialtone.daemon.log_path" "$daemon_log" >/dev/null || true
    fi
    ensure_worker_async_fast >/dev/null || true
    if shell_worker_healthy_fast; then
      clear_state_value "shell.ensure.pid" >/dev/null || true
      clear_state_value "shell.ensure.log_path" >/dev/null || true
      clear_state_value "shell.ensure.started_at" >/dev/null || true
    fi
    sleep 1
  done
}

load_tmux_target() {
  local raw=""
  if [ -n "${DIALTONE_TMUX_TARGET:-}" ]; then
    printf '%s' "${DIALTONE_TMUX_TARGET}"
    return
  fi
  raw="$(run_sqlite_query "$DIALTONE_STATE_DB" "select value from state_values where scope = 'system' and key = 'tmux.target' limit 1;" 2>/dev/null || true)"
  raw="$(printf '%s' "$raw" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
  if [ -n "$raw" ]; then
    printf '%s' "$raw"
    return
  fi
  printf '%s' ""
}

load_tmux_prompt_target() {
  local raw=""
  raw="$(run_sqlite_query "$DIALTONE_STATE_DB" "select value from state_values where scope = 'system' and key = 'tmux.prompt_target' limit 1;" 2>/dev/null || true)"
  raw="$(printf '%s' "$raw" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
  printf '%s' "$raw"
}

should_route_via_shell() {
  local mod="${1:-}"
  local version="${2:-}"
  local command="${3:-}"
  case "${mod}:${version}:${command}" in
    "shell:v1:"*|"tmux:v1:"*|"ghostty:v1:"*|"test:v1:"*)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

current_tmux_pane_target() {
  if [ -z "${TMUX_PANE:-}" ] || ! command -v tmux >/dev/null 2>&1; then
    return 0
  fi
  tmux display-message -p -t "$TMUX_PANE" "#{session_name}:#{window_index}:#{pane_index}" 2>/dev/null | tr -d '\r'
}

rfc3339_to_epoch() {
  local raw="${1:-}"
  local value=""
  if [ -z "$raw" ]; then
    return 1
  fi
  value="$(printf '%s' "$raw" | tr -d '\r' | sed -e 's/\.[0-9][0-9]*Z$/Z/')"
  if date -u -j -f "%Y-%m-%dT%H:%M:%SZ" "$value" "+%s" >/dev/null 2>&1; then
    date -u -j -f "%Y-%m-%dT%H:%M:%SZ" "$value" "+%s"
    return 0
  fi
  if date -u -d "$value" "+%s" >/dev/null 2>&1; then
    date -u -d "$value" "+%s"
    return 0
  fi
  return 1
}

process_alive() {
  local pid="${1:-}"
  if [ -z "$pid" ] || ! [[ "$pid" =~ ^[0-9]+$ ]] || [ "$pid" -le 0 ]; then
    return 1
  fi
  kill -0 "$pid" 2>/dev/null
}

shell_worker_healthy_fast() {
  local worker_status=""
  local worker_pane=""
  local worker_heartbeat=""
  local now_epoch=0
  local heartbeat_epoch=0
  local age=0

  worker_status="$(load_state_value "shell.worker.status")"
  worker_pane="$(load_state_value "shell.worker.pane")"
  worker_heartbeat="$(load_state_value "shell.worker.heartbeat_at")"
  if [ "$worker_status" != "running" ] || [ -z "$worker_pane" ] || [ -z "$worker_heartbeat" ]; then
    return 1
  fi
  if ! heartbeat_epoch="$(rfc3339_to_epoch "$worker_heartbeat")"; then
    return 1
  fi
  now_epoch="$(date -u +%s)"
  age=$((now_epoch - heartbeat_epoch))
  [ "$age" -le 10 ]
}

should_execute_direct_in_pane_fast() {
  local current_pane=""
  local command_text=""
  local match=""

  current_pane="$(current_tmux_pane_target)"
  if [ -z "$current_pane" ] || [ ! -f "$DIALTONE_STATE_DB" ]; then
    return 1
  fi
  command_text="$(build_dialtone_command "$@")"
  match="$(run_sqlite_query "$DIALTONE_STATE_DB" "
select 1
from shell_bus
where scope = 'desired'
  and subject = 'command'
  and action = 'run'
  and status = 'running'
  and (trim(pane) = '' or trim(pane) = '$(sql_quote "$current_pane")')
  and (
    trim(json_extract(body_json, '$.inner_command')) = '$(sql_quote "$command_text")'
    or trim(json_extract(body_json, '$.command')) = '$(sql_quote "$command_text")'
  )
order by id desc
limit 1;
" 2>/dev/null || true)"
  [ "$(printf '%s' "$match" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')" = "1" ]
}

queue_command_via_shell_fast() {
  local session="${1:-codex-view}"
  local command_target="${2:-}"
  local display_command="${3:-}"
  local now=""

  ensure_fast_route_schema
  now="$(now_utc_rfc3339)"
  run_sqlite_query "$DIALTONE_STATE_DB" "
insert into shell_bus(system, scope, subject, action, status, actor, session, pane, ref_id, body_json, created_at, updated_at)
values(
  'shell',
  'desired',
  'command',
  'run',
  'queued',
  'dialtone_mod',
  '$(sql_quote "$session")',
  '$(sql_quote "$command_target")',
  0,
  json_object(
    'command', '$(sql_quote "$display_command")',
    'inner_command', '$(sql_quote "$display_command")',
    'display_command', '$(sql_quote "$display_command")',
    'target', '$(sql_quote "$command_target")'
  ),
  '$(sql_quote "$now")',
  '$(sql_quote "$now")'
);
select last_insert_rowid();
"
}

ensure_worker_async_fast() {
  local pid=""
  local log_path=""
  local log_dir=""
  local started_at=""

  pid="$(load_state_value "shell.ensure.pid")"
  log_path="$(load_state_value "shell.ensure.log_path")"
  if shell_worker_healthy_fast; then
    if process_alive "$pid"; then
      printf '%s\t%s\t%s\n' "$pid" "$log_path" "existing"
      return 0
    fi
    printf '\t\tworker\n'
    return 0
  fi
  if process_alive "$pid"; then
    printf '%s\t%s\t%s\n' "$pid" "$log_path" "existing"
    return 0
  fi
  log_dir="$DIALTONE_STATE_DIR/logs"
  mkdir -p "$log_dir"
  log_path="$log_dir/dialtone-ensure-$(date -u +%s)-$$-${RANDOM:-0}.log"
  nohup "$REPO_ROOT/dialtone_mod" shell v1 ensure-worker --wait-seconds 30 >"$log_path" 2>&1 </dev/null &
  pid="$!"
  started_at="$(now_utc_rfc3339)"
  upsert_state_value "shell.ensure.pid" "$pid" >/dev/null
  upsert_state_value "shell.ensure.log_path" "$log_path" >/dev/null
  upsert_state_value "shell.ensure.started_at" "$started_at" >/dev/null
  printf '%s\t%s\t%s\n' "$pid" "$log_path" "started"
}

load_dialtone_process_rows() {
  ps -axo pid=,ppid=,stat=,tt=,command= | awk '
{
  pid=$1
  ppid=$2
  stat=$3
  tty=$4
  $1=""
  $2=""
  $3=""
  $4=""
  sub(/^[[:space:]]+/, "", $0)
  cmd=$0
  if (cmd ~ /^awk / || cmd ~ / ps -axo / || cmd ~ /^ps -axo / || cmd ~ / rg /) {
    next
  }
  if (cmd ~ /(^|[[:space:]\/])dialtone_mod([[:space:]]|$)/ && cmd !~ /__dialtone serve/) {
    role="dialtone_mod"
  } else if (cmd ~ /(^|[[:space:]])dialtone([[:space:]]|$)/ || cmd ~ /__dialtone serve/) {
    role="dialtone"
  } else if (cmd ~ /go run \.\/mods\.go shell v1 serve/ || cmd ~ /\/mods shell v1 serve/) {
    role="worker"
  } else if (cmd ~ /go run \.\/mods\.go shell v1 ensure-worker/ || cmd ~ /\/mods shell v1 ensure-worker/) {
    role="ensure"
  } else {
    next
  }
  background=(tty == "??" || stat !~ /\+/) ? "yes" : "no"
  printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\n", pid, ppid, stat, tty, role, background, cmd
}'
}

summarize_dialtone_process_rows() {
  local process_rows="${1:-}"
  local total=0
  local total_background=0
  local client_total=0
  local client_background=0
  local daemon_total=0
  local worker_total=0
  local ensure_total=0
  local pid=""
  local ppid=""
  local stat=""
  local tty=""
  local role=""
  local background=""
  local command=""

  if [ -n "$process_rows" ]; then
    while IFS=$'\t' read -r pid ppid stat tty role background command; do
      [ -n "$pid" ] || continue
      total=$((total + 1))
      if [ "$background" = "yes" ]; then
        total_background=$((total_background + 1))
      fi
      case "$role" in
        dialtone_mod)
          client_total=$((client_total + 1))
          if [ "$background" = "yes" ]; then
            client_background=$((client_background + 1))
          fi
          ;;
        dialtone)
          daemon_total=$((daemon_total + 1))
          ;;
        worker)
          worker_total=$((worker_total + 1))
          ;;
        ensure)
          ensure_total=$((ensure_total + 1))
          ;;
      esac
    done <<<"$process_rows"
  fi

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$total" \
    "$total_background" \
    "$client_total" \
    "$client_background" \
    "$daemon_total" \
    "$worker_total" \
    "$ensure_total"
}

print_fast_route_report() {
  local row_id="${1:-0}"
  local display_command="${2:-}"
  local command_target="${3:-}"
  local daemon_pid="${4:-}"
  local daemon_log="${5:-}"
  local daemon_state="${6:-}"
  local bootstrap_status=""
  local bootstrap_mode=""
  local bootstrap_shell=""
  local bootstrap_log=""
  local persisted_daemon_pid=""
  local persisted_daemon_status=""
  local persisted_daemon_log=""
  local worker_status=""
  local worker_pane=""
  local worker_current_row=""
  local worker_last_row=""
  local worker_last_status=""
  local worker_last_exit_code=""
  local worker_last_summary=""
  local process_rows=""
  local process_summary=""
  local process_count=0
  local background_count=0
  local client_process_count=0
  local client_background_count=0
  local daemon_process_count=0
  local worker_process_count=0
  local ensure_process_count=0
  local pid=""
  local ppid=""
  local stat=""
  local tty=""
