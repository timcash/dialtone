#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${DIALTONE_REPO_ROOT:-$SCRIPT_DIR}"
USE_NIX="${DIALTONE_USE_NIX:-1}"
DIALTONE_HOME_ROOT="${HOME:-$SCRIPT_DIR}"
DIALTONE_STATE_DIR="${DIALTONE_STATE_DIR:-$DIALTONE_HOME_ROOT/.dialtone}"
DIALTONE_STATE_DB="${DIALTONE_STATE_DB:-$DIALTONE_STATE_DIR/state.sqlite}"
DIALTONE_TMUX_TARGET_FILE="${DIALTONE_TMUX_TARGET_FILE:-$DIALTONE_STATE_DIR/tmux_target}"
declare -a DIALTONE_NIX_PACKAGES=()

mkdir -p "$DIALTONE_STATE_DIR"

rewrite_nix_package_ref() {
  local pkg="${1:-}"
  if [[ "$pkg" == nixpkgs#* ]] && [ "$NIXPKGS_FLAKE_REF" != "nixpkgs" ]; then
    printf '%s#%s' "$NIXPKGS_FLAKE_REF" "${pkg#nixpkgs#}"
    return
  fi
  printf '%s' "$pkg"
}

shell_quote() {
  printf "%q" "${1:-}"
}

join_shell_args() {
  local out=""
  local arg=""
  for arg in "$@"; do
    if [ -n "$out" ]; then
      out+=" "
    fi
    out+="$(shell_quote "$arg")"
  done
  printf '%s' "$out"
}

hydrate_env_from_state_db() {
  local key=""
  local value=""

  if [ ! -f "$DIALTONE_STATE_DB" ]; then
    return 0
  fi

  while IFS=$'\t' read -r key value; do
    if [ -z "$key" ]; then
      continue
    fi
    case "$key" in
      DIALTONE_TMUX_PROXY_ACTIVE|DIALTONE_TMUX_TARGET|DIALTONE_TMUX_TARGET_FILE|DIALTONE_NIX_ACTIVE|DIALTONE_NIX_BASE_PATH|DIALTONE_NIX_PACKAGES_SIG|DIALTONE_NIX_SHELL)
        continue
        ;;
    esac
    if [[ "$key" != DIALTONE_* ]] && [ "$key" != "NIXPKGS_FLAKE" ]; then
      continue
    fi
    if [ -n "${!key:-}" ]; then
      continue
    fi
    export "$key=$value"
  done < <(
    run_sqlite_query "$DIALTONE_STATE_DB" \
      "select key, value from runtime_env where scope = 'process' and (key like 'DIALTONE_%' or key = 'NIXPKGS_FLAKE') order by key;" \
      2>/dev/null || true
  )
}

run_sqlite_query() {
  local db_path="${1:-}"
  local query="${2:-}"
  local flake_ref="${DIALTONE_NIXPKGS_FLAKE:-${NIXPKGS_FLAKE:-nixpkgs}}"
  local nix_args=()

  if [ -z "$db_path" ] || [ -z "$query" ] || [ ! -f "$db_path" ]; then
    return 1
  fi
  if command -v sqlite3 >/dev/null 2>&1; then
    sqlite3 -tabs -noheader "$db_path" "$query"
    return
  fi
  if ! command -v nix >/dev/null 2>&1; then
    return 1
  fi
  if [ "${DIALTONE_NIX_OFFLINE:-0}" = "1" ]; then
    nix_args+=(--offline)
  fi
  nix \
    "${nix_args[@]}" \
    --extra-experimental-features "nix-command flakes" \
    shell "${flake_ref}#sqlite" \
    --command sqlite3 -tabs -noheader "$db_path" "$query"
}

run_sqlite_exec() {
  local db_path="${1:-}"
  local query="${2:-}"
  run_sqlite_query "$db_path" "$query" >/dev/null
}

load_tmux_target() {
  local raw=""
  if [ -n "${DIALTONE_TMUX_TARGET:-}" ]; then
    printf '%s' "${DIALTONE_TMUX_TARGET}"
    return
  fi
  raw="$(run_sqlite_query "$DIALTONE_STATE_DB" "select value from state_values where scope = 'system' and key = 'tmux.target' limit 1;" 2>/dev/null || true)"
  raw="$(printf '%s' "$raw" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
  if [ -n "$raw" ]; then
    printf '%s' "$raw"
    return
  fi
  printf '%s' ""
}

load_tmux_prompt_target() {
  local raw=""
  raw="$(run_sqlite_query "$DIALTONE_STATE_DB" "select value from state_values where scope = 'system' and key = 'tmux.prompt_target' limit 1;" 2>/dev/null || true)"
  raw="$(printf '%s' "$raw" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
  printf '%s' "$raw"
}

should_route_via_shell() {
  local mod="${1:-}"
  local version="${2:-}"
  local command="${3:-}"
  case "${mod}:${version}:${command}" in
    "shell:v1:"*|"tmux:v1:"*|"ghostty:v1:"*|"mod:v1:db")
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

run_go_in_default_nix() {
  local subcommand="${1:-exec}"
  shift || true
  declare -a NIX_ARGS=()
  local quoted_args=""
  if [ "${DIALTONE_NIX_OFFLINE:-0}" = "1" ]; then
    NIX_ARGS+=(--offline)
  fi
  if [ "${DIALTONE_NIX_ACTIVE:-0}" = "1" ] || [ "$USE_NIX" = "0" ]; then
    cd "$REPO_ROOT/src"
    if [ "$subcommand" = "capture" ]; then
      "${DIALTONE_GO_BIN:-go}" run ./mods.go "$@"
      return
    fi
    exec "${DIALTONE_GO_BIN:-go}" run ./mods.go "$@"
  fi
  if ! command -v nix >/dev/null 2>&1; then
    echo "DIALTONE> nix is required for dialtone_mod (set DIALTONE_USE_NIX=0 to bypass)" >&2
    exit 1
  fi
  quoted_args="$(join_shell_args "$@")"
  if [ "$subcommand" = "capture" ]; then
    nix \
      "${NIX_ARGS[@]}" \
      --extra-experimental-features "nix-command flakes" \
      develop "path:$REPO_ROOT#default" \
      --command env \
        DIALTONE_NIX_ACTIVE=1 \
        DIALTONE_NIX_SHELL="default" \
        DIALTONE_HOST_PATH="$PATH" \
        DIALTONE_REPO_ROOT="$REPO_ROOT" \
        DIALTONE_STATE_DIR="$DIALTONE_STATE_DIR" \
        DIALTONE_STATE_DB="$DIALTONE_STATE_DB" \
        DIALTONE_NIX_OFFLINE="${DIALTONE_NIX_OFFLINE:-0}" \
        DIALTONE_USE_NIX="$USE_NIX" \
        zsh -lc "cd $(shell_quote "$REPO_ROOT/src") && \${DIALTONE_GO_BIN:-go} run ./mods.go $quoted_args"
    return
  fi
  exec nix \
    "${NIX_ARGS[@]}" \
    --extra-experimental-features "nix-command flakes" \
    develop "path:$REPO_ROOT#default" \
    --command env \
      DIALTONE_NIX_ACTIVE=1 \
      DIALTONE_NIX_SHELL="default" \
      DIALTONE_HOST_PATH="$PATH" \
      DIALTONE_REPO_ROOT="$REPO_ROOT" \
      DIALTONE_STATE_DIR="$DIALTONE_STATE_DIR" \
      DIALTONE_STATE_DB="$DIALTONE_STATE_DB" \
      DIALTONE_NIX_OFFLINE="${DIALTONE_NIX_OFFLINE:-0}" \
      DIALTONE_USE_NIX="$USE_NIX" \
      zsh -lc "cd $(shell_quote "$REPO_ROOT/src") && exec \${DIALTONE_GO_BIN:-go} run ./mods.go $quoted_args"
}

if [ ! -f "$REPO_ROOT/src/mods.go" ]; then
  echo "DIALTONE> src/mods.go not found under $REPO_ROOT" >&2
  exit 1
fi

if [ ! -d "$REPO_ROOT/src/mods" ]; then
  echo "DIALTONE> src/mods not found under $REPO_ROOT" >&2
  exit 1
fi

hydrate_env_from_state_db
REPO_ROOT="${DIALTONE_REPO_ROOT:-$REPO_ROOT}"
USE_NIX="${DIALTONE_USE_NIX:-$USE_NIX}"
DIALTONE_HOME_ROOT="${HOME:-$REPO_ROOT}"
DIALTONE_STATE_DIR="${DIALTONE_STATE_DIR:-$DIALTONE_HOME_ROOT/.dialtone}"
DIALTONE_STATE_DB="${DIALTONE_STATE_DB:-$DIALTONE_STATE_DIR/state.sqlite}"
DIALTONE_TMUX_TARGET_FILE="${DIALTONE_TMUX_TARGET_FILE:-$DIALTONE_STATE_DIR/tmux_target}"
NIXPKGS_FLAKE_REF="${DIALTONE_NIXPKGS_FLAKE:-${NIXPKGS_FLAKE:-nixpkgs}}"
mkdir -p "$DIALTONE_STATE_DIR"

add_nix_package() {
  local pkg="$1"
  if [ -z "$pkg" ]; then
    return
  fi
  pkg="$(rewrite_nix_package_ref "$pkg")"
  local existing=""
  for existing in "${DIALTONE_NIX_PACKAGES[@]:-}"; do
    if [ "$existing" = "$pkg" ]; then
      return
    fi
  done
  DIALTONE_NIX_PACKAGES+=("$pkg")
}

join_nix_package_sig() {
  local out=""
  local pkg=""
  for pkg in "${DIALTONE_NIX_PACKAGES[@]:-}"; do
    if [ -n "$out" ]; then
      out="${out},"
    fi
    out="${out}${pkg}"
  done
  printf '%s' "$out"
}

add_nix_package "nixpkgs#bashInteractive"
add_nix_package "nixpkgs#git"
add_nix_package "nixpkgs#go_1_25"
FLAKE_SHELL=""
while IFS=$'\t' read -r plan_kind plan_value; do
  case "$plan_kind" in
    "flake_shell")
      FLAKE_SHELL="$plan_value"
      ;;
    "package")
      add_nix_package "$plan_value"
      ;;
  esac
done < <(
  run_go_in_default_nix capture __nix-plan "${1:-}" "${2:-}" 2>/dev/null || true
)
NIX_PACKAGE_SIG="$(join_nix_package_sig)"
TMUX_TARGET="$(load_tmux_target)"
TMUX_PROMPT_TARGET="$(load_tmux_prompt_target)"

if [ -n "$TMUX_TARGET" ] && [ -n "$TMUX_PROMPT_TARGET" ] && [ "${DIALTONE_TMUX_PROXY_ACTIVE:-0}" != "1" ] && should_route_via_shell "${1:-}" "${2:-}" "${3:-}"; then
  run_go_in_default_nix exec "$@"
fi

if [ "$USE_NIX" != "0" ] && [ -n "$FLAKE_SHELL" ] && [ "${DIALTONE_NIX_ACTIVE:-0}" != "1" ]; then
  if ! command -v nix >/dev/null 2>&1; then
    echo "DIALTONE> nix is required for dialtone_mod (set DIALTONE_USE_NIX=0 to bypass)" >&2
    exit 1
  fi
  declare -a NIX_ARGS=()
  if [ "${DIALTONE_NIX_OFFLINE:-0}" = "1" ]; then
    NIX_ARGS+=(--offline)
  fi
  exec nix \
    "${NIX_ARGS[@]}" \
    --extra-experimental-features "nix-command flakes" \
    develop "path:$REPO_ROOT#$FLAKE_SHELL" \
    --command env \
      DIALTONE_NIX_ACTIVE=1 \
      DIALTONE_NIX_SHELL="$FLAKE_SHELL" \
      DIALTONE_HOST_PATH="$PATH" \
      DIALTONE_REPO_ROOT="$REPO_ROOT" \
      DIALTONE_STATE_DIR="$DIALTONE_STATE_DIR" \
      DIALTONE_STATE_DB="$DIALTONE_STATE_DB" \
      DIALTONE_NIX_OFFLINE="${DIALTONE_NIX_OFFLINE:-0}" \
      DIALTONE_USE_NIX="$USE_NIX" \
      "$REPO_ROOT/dialtone_mod" "$@"
fi

if [ "$USE_NIX" != "0" ] && [ -z "$FLAKE_SHELL" ] && [ "${DIALTONE_NIX_ACTIVE:-0}" != "1" ]; then
  if ! command -v nix >/dev/null 2>&1; then
    echo "DIALTONE> nix is required for dialtone_mod (set DIALTONE_USE_NIX=0 to bypass)" >&2
    exit 1
  fi
  declare -a NIX_ARGS=()
  if [ "${DIALTONE_NIX_OFFLINE:-0}" = "1" ]; then
    NIX_ARGS+=(--offline)
  fi
  exec nix \
    "${NIX_ARGS[@]}" \
    --extra-experimental-features "nix-command flakes" \
    shell \
    "${DIALTONE_NIX_PACKAGES[@]}" \
    --command env \
      DIALTONE_NIX_ACTIVE=1 \
      DIALTONE_NIX_PACKAGES_SIG="$NIX_PACKAGE_SIG" \
      DIALTONE_NIXPKGS_FLAKE="$NIXPKGS_FLAKE_REF" \
      NIXPKGS_FLAKE="$NIXPKGS_FLAKE_REF" \
      DIALTONE_HOST_PATH="$PATH" \
      DIALTONE_REPO_ROOT="$REPO_ROOT" \
      DIALTONE_STATE_DIR="$DIALTONE_STATE_DIR" \
      DIALTONE_STATE_DB="$DIALTONE_STATE_DB" \
      DIALTONE_NIX_OFFLINE="${DIALTONE_NIX_OFFLINE:-0}" \
      DIALTONE_USE_NIX="$USE_NIX" \
      "$REPO_ROOT/dialtone_mod" "$@"
fi

cd "$REPO_ROOT/src"
exec "${DIALTONE_GO_BIN:-go}" run ./mods.go "$@"
