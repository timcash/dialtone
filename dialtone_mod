#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${DIALTONE_REPO_ROOT:-$SCRIPT_DIR}"
USE_NIX="${DIALTONE_USE_NIX:-1}"
DIALTONE_HOME_ROOT="${HOME:-$SCRIPT_DIR}"
DIALTONE_STATE_DIR="${DIALTONE_STATE_DIR:-$DIALTONE_HOME_ROOT/.dialtone}"
DIALTONE_STATE_DB="${DIALTONE_STATE_DB:-$DIALTONE_STATE_DIR/state.sqlite}"
DIALTONE_BIN_DIR="${DIALTONE_BIN_DIR:-$DIALTONE_STATE_DIR/bin}"
DIALTONE_TMUX_TARGET_FILE="${DIALTONE_TMUX_TARGET_FILE:-$DIALTONE_STATE_DIR/tmux_target}"
declare -a DIALTONE_NIX_PACKAGES=()

mkdir -p "$DIALTONE_STATE_DIR"

rewrite_nix_package_ref() {
  local pkg="${1:-}"
  if [[ "$pkg" == nixpkgs#* ]] && [ "$NIXPKGS_FLAKE_REF" != "nixpkgs" ]; then
    printf '%s#%s' "$NIXPKGS_FLAKE_REF" "${pkg#nixpkgs#}"
    return
  fi
  printf '%s' "$pkg"
}

shell_quote() {
  printf "%q" "${1:-}"
}

join_shell_args() {
  local out=""
  local arg=""
  for arg in "$@"; do
    if [ -n "$out" ]; then
      out+=" "
    fi
    out+="$(shell_quote "$arg")"
  done
  printf '%s' "$out"
}

build_dialtone_command() {
  local quoted_args=""
  quoted_args="$(join_shell_args "$@")"
  if [ -n "$quoted_args" ]; then
    printf './dialtone_mod %s' "$quoted_args"
    return
  fi
  printf './dialtone_mod'
}

sql_quote() {
  printf '%s' "${1:-}" | sed "s/'/''/g"
}

trim_text() {
  printf '%s' "${1:-}" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//'
}

now_utc_rfc3339() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

hydrate_env_from_state_db() {
  local key=""
  local value=""

  if [ ! -f "$DIALTONE_STATE_DB" ]; then
    return 0
  fi

  while IFS=$'\t' read -r key value; do
    if [ -z "$key" ]; then
      continue
    fi
    case "$key" in
      DIALTONE_TMUX_PROXY_ACTIVE|DIALTONE_TMUX_TARGET|DIALTONE_TMUX_TARGET_FILE|DIALTONE_NIX_ACTIVE|DIALTONE_NIX_BASE_PATH|DIALTONE_NIX_PACKAGES_SIG|DIALTONE_NIX_SHELL)
        continue
        ;;
    esac
    if [[ "$key" != DIALTONE_* ]] && [ "$key" != "NIXPKGS_FLAKE" ]; then
      continue
    fi
    if [ -n "${!key:-}" ]; then
      continue
    fi
    export "$key=$value"
  done < <(
    run_sqlite_query "$DIALTONE_STATE_DB" \
      "select key, value from runtime_env where scope = 'process' and (key like 'DIALTONE_%' or key = 'NIXPKGS_FLAKE') order by key;" \
      2>/dev/null || true
  )
}

run_sqlite_query() {
  local db_path="${1:-}"
  local query="${2:-}"
  local flake_ref="${DIALTONE_NIXPKGS_FLAKE:-${NIXPKGS_FLAKE:-nixpkgs}}"
  local nix_args=()

  if [ -z "$db_path" ] || [ -z "$query" ] || [ ! -f "$db_path" ]; then
    return 1
  fi
  if command -v sqlite3 >/dev/null 2>&1; then
    sqlite3 -cmd ".timeout 5000" -tabs -noheader "$db_path" "$query"
    return
  fi
  if ! command -v nix >/dev/null 2>&1; then
    return 1
  fi
  if [ "${DIALTONE_NIX_OFFLINE:-0}" = "1" ]; then
    nix_args+=(--offline)
  fi
  nix \
    "${nix_args[@]}" \
    --extra-experimental-features "nix-command flakes" \
    shell "${flake_ref}#sqlite" \
    --command sqlite3 -cmd ".timeout 5000" -tabs -noheader "$db_path" "$query"
}

run_sqlite_exec() {
  local db_path="${1:-}"
  local query="${2:-}"
  run_sqlite_query "$db_path" "$query" >/dev/null
}

run_sqlite_script() {
  local db_path="${1:-}"
  local flake_ref="${DIALTONE_NIXPKGS_FLAKE:-${NIXPKGS_FLAKE:-nixpkgs}}"
  local nix_args=()

  if [ -z "$db_path" ]; then
    return 1
  fi
  mkdir -p "$(dirname "$db_path")"
  if command -v sqlite3 >/dev/null 2>&1; then
    sqlite3 -cmd ".timeout 5000" -tabs -noheader "$db_path"
    return
  fi
  if ! command -v nix >/dev/null 2>&1; then
    return 1
  fi
  if [ "${DIALTONE_NIX_OFFLINE:-0}" = "1" ]; then
    nix_args+=(--offline)
  fi
  nix \
    "${nix_args[@]}" \
    --extra-experimental-features "nix-command flakes" \
    shell "${flake_ref}#sqlite" \
    --command sqlite3 -cmd ".timeout 5000" -tabs -noheader "$db_path"
}

ensure_fast_route_schema() {
  run_sqlite_script "$DIALTONE_STATE_DB" <<'SQL' >/dev/null
PRAGMA journal_mode=WAL;
PRAGMA foreign_keys=ON;
PRAGMA busy_timeout=1000;
create table if not exists state_values (
  scope text not null,
  key text not null,
  value text not null,
  updated_at text not null,
  primary key (scope, key)
);
create table if not exists shell_bus (
  id integer primary key autoincrement,
  system text not null,
  scope text not null,
  subject text not null,
  action text not null,
  status text not null,
  actor text not null,
  session text not null default '',
  pane text not null default '',
  ref_id integer not null default 0,
  body_json text not null default '',
  created_at text not null,
  updated_at text not null
);
SQL
}

load_state_value() {
  local key="${1:-}"
  local raw=""
  if [ -z "$key" ] || [ ! -f "$DIALTONE_STATE_DB" ]; then
    return 0
  fi
  raw="$(run_sqlite_query "$DIALTONE_STATE_DB" "select value from state_values where scope = 'system' and key = '$(sql_quote "$key")' limit 1;" 2>/dev/null || true)"
  raw="$(printf '%s' "$raw" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
  printf '%s' "$raw"
}

upsert_state_value() {
  local key="${1:-}"
  local value="${2:-}"
  local now=""
  if [ -z "$key" ]; then
    return 1
  fi
  ensure_fast_route_schema
  now="$(now_utc_rfc3339)"
  run_sqlite_exec "$DIALTONE_STATE_DB" "
insert into state_values(scope, key, value, updated_at)
values('system', '$(sql_quote "$key")', '$(sql_quote "$value")', '$(sql_quote "$now")')
on conflict(scope, key) do update set
  value = excluded.value,
  updated_at = excluded.updated_at;
"
}

ensure_bootstrap_state() {
  local bootstrap_status=""
  local bootstrap_log=""
  local bootstrap_time=""
  local log_dir=""

  bootstrap_status="$(load_state_value "bootstrap.status")"
  if [ "$bootstrap_status" = "ready" ]; then
    return 0
  fi

  ensure_fast_route_schema
  log_dir="$DIALTONE_STATE_DIR/logs"
  mkdir -p "$log_dir"
  bootstrap_time="$(now_utc_rfc3339)"
  bootstrap_log="$log_dir/bootstrap-$(date -u +%s)-$$.log"
  {
    printf 'dialtone bootstrap (simulated)\n'
    printf 'completed_at=%s\n' "$bootstrap_time"
    printf 'repo_root=%s\n' "$REPO_ROOT"
    printf 'default_shell=default\n'
    printf 'sqlite_runtime=nix-managed\n'
    printf 'worker_runtime=nix-managed\n'
    printf 'notes=First-run bootstrap would prefetch the default dev shell and sqlite runtime here.\n'
  } >"$bootstrap_log"

  upsert_state_value "bootstrap.status" "ready" >/dev/null
  upsert_state_value "bootstrap.mode" "simulated" >/dev/null
  upsert_state_value "bootstrap.shell" "default" >/dev/null
  upsert_state_value "bootstrap.sqlite_runtime" "nix-managed" >/dev/null
  upsert_state_value "bootstrap.worker_runtime" "nix-managed" >/dev/null
  upsert_state_value "bootstrap.log_path" "$bootstrap_log" >/dev/null
  upsert_state_value "bootstrap.completed_at" "$bootstrap_time" >/dev/null
}

exec_dialtone_internal() {
  local binary=""
  ensure_dialtone_binary >/dev/null
  binary="$(dialtone_binary_path)"
  exec "$binary" "$@"
}

dialtone_binary_path() {
  printf '%s' "$DIALTONE_BIN_DIR/dialtone"
}

dialtone_binary_needs_build() {
  local binary="${1:-}"
  if [ -z "$binary" ] || [ ! -x "$binary" ]; then
    return 0
  fi
  find \
    "$REPO_ROOT/src/internal" \
    "$REPO_ROOT/src/mods/shared" \
    "$REPO_ROOT/src/mods/dialtone" \
    "$REPO_ROOT/src/go.mod" \
    "$REPO_ROOT/src/go.sum" \
    -type f \
    \( -name '*.go' -o -name 'go.mod' -o -name 'go.sum' \) \
    -newer "$binary" \
    -print -quit 2>/dev/null | grep -q .
}

build_dialtone_binary() {
  local binary="${1:-}"
  local nix_cmd=()
  if [ -z "$binary" ]; then
    return 1
  fi
  mkdir -p "$(dirname "$binary")"
  if [ "${DIALTONE_NIX_ACTIVE:-0}" = "1" ] || [ "$USE_NIX" = "0" ]; then
    (
      cd "$REPO_ROOT/src"
      "${DIALTONE_GO_BIN:-go}" build -o "$binary" ./mods/dialtone/v1
    )
    return
  fi
  if ! command -v nix >/dev/null 2>&1; then
    echo "DIALTONE> nix is required to build the dialtone binary" >&2
    return 1
  fi
  if [ "${DIALTONE_NIX_OFFLINE:-0}" = "1" ]; then
    nix_cmd+=(--offline)
  fi
  nix \
    "${nix_cmd[@]}" \
    --extra-experimental-features "nix-command flakes" \
    develop "path:$REPO_ROOT#default" \
    --command env \
      DIALTONE_NIX_ACTIVE=1 \
      DIALTONE_NIX_SHELL="default" \
      DIALTONE_HOST_PATH="$PATH" \
      DIALTONE_REPO_ROOT="$REPO_ROOT" \
      DIALTONE_STATE_DIR="$DIALTONE_STATE_DIR" \
      DIALTONE_STATE_DB="$DIALTONE_STATE_DB" \
      DIALTONE_BIN_DIR="$DIALTONE_BIN_DIR" \
      DIALTONE_NIX_OFFLINE="${DIALTONE_NIX_OFFLINE:-0}" \
      DIALTONE_USE_NIX="$USE_NIX" \
      zsh -lc "cd $(shell_quote "$REPO_ROOT/src") && exec \${DIALTONE_GO_BIN:-go} build -o $(shell_quote "$binary") ./mods/dialtone/v1"
}

ensure_dialtone_binary() {
  local binary=""
  binary="$(dialtone_binary_path)"
  if [ ! -x "$binary" ] || dialtone_binary_needs_build "$binary"; then
    build_dialtone_binary "$binary" >&2
  fi
  printf '%s' "$binary"
}

should_route_via_shell() {
  local mod="${1:-}"
  local version="${2:-}"
  local command="${3:-}"
  case "${mod}:${version}:${command}" in
    "shell:v1:"*|"tmux:v1:"*|"ghostty:v1:"*|"test:v1:"*|"dialtone:v1:"*|"codex:v1:"*)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

current_tmux_pane_target() {
  if [ -n "${DIALTONE_TMUX_TARGET:-}" ]; then
    printf '%s' "${DIALTONE_TMUX_TARGET}" | tr -d '\r'
    return 0
  fi
  if [ -z "${TMUX_PANE:-}" ] || ! command -v tmux >/dev/null 2>&1; then
    return 0
  fi
  tmux display-message -p -t "$TMUX_PANE" "#{session_name}:#{window_index}:#{pane_index}" 2>/dev/null | tr -d '\r'
}

should_execute_direct_in_pane_fast() {
  local current_pane=""
  local command_text=""
  local match=""

  current_pane="$(current_tmux_pane_target)"
  if [ -z "$current_pane" ] || [ ! -f "$DIALTONE_STATE_DB" ]; then
    return 1
  fi
  command_text="$(build_dialtone_command "$@")"
  match="$(run_sqlite_query "$DIALTONE_STATE_DB" "
select 1
from shell_bus
where scope = 'desired'
  and subject = 'command'
  and action = 'run'
  and status = 'running'
  and (trim(pane) = '' or trim(pane) = '$(sql_quote "$current_pane")')
  and (
    trim(json_extract(body_json, '$.inner_command')) = '$(sql_quote "$command_text")'
    or trim(json_extract(body_json, '$.command')) = '$(sql_quote "$command_text")'
  )
order by id desc
limit 1;
" 2>/dev/null || true)"
  [ "$(printf '%s' "$match" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')" = "1" ]
}

FAST_STATUS_ROW_ID=""
FAST_STATUS_FULL=0

parse_fast_shell_status_args() {
  FAST_STATUS_ROW_ID=""
  FAST_STATUS_FULL=0
  while [ "$#" -gt 0 ]; do
    case "${1:-}" in
      --row-id)
        [ "$#" -ge 2 ] || return 1
        FAST_STATUS_ROW_ID="$(trim_text "${2:-}")"
        shift 2
        ;;
      --row-id=*)
        FAST_STATUS_ROW_ID="$(trim_text "${1#*=}")"
        shift
        ;;
      --full|--full=true)
        FAST_STATUS_FULL=1
        shift
        ;;
      --full=false)
        FAST_STATUS_FULL=0
        shift
        ;;
      --sync)
        if [ "$#" -ge 2 ] && [[ "${2:-}" != -* ]]; then
          shift 2
        else
          shift
        fi
        ;;
      --sync=*)
        shift
        ;;
      --limit)
        [ "$#" -ge 2 ] || return 1
        shift 2
        ;;
      --limit=*)
        shift
        ;;
      *)
        return 1
        ;;
    esac
  done
  if [ -n "$FAST_STATUS_ROW_ID" ] && ! [[ "$FAST_STATUS_ROW_ID" =~ ^[0-9]+$ ]]; then
    return 1
  fi
  return 0
}

run_go_in_default_nix() {
  local subcommand="${1:-exec}"
  shift || true
  declare -a NIX_ARGS=()
  local quoted_args=""
  if [ "${DIALTONE_NIX_OFFLINE:-0}" = "1" ]; then
    NIX_ARGS+=(--offline)
  fi
  if [ "${DIALTONE_NIX_ACTIVE:-0}" = "1" ] || [ "$USE_NIX" = "0" ]; then
    cd "$REPO_ROOT/src"
    if [ "$subcommand" = "capture" ]; then
      "${DIALTONE_GO_BIN:-go}" run ./mods.go "$@"
      return
    fi
    exec "${DIALTONE_GO_BIN:-go}" run ./mods.go "$@"
  fi
  if ! command -v nix >/dev/null 2>&1; then
    echo "DIALTONE> nix is required for dialtone_mod (set DIALTONE_USE_NIX=0 to bypass)" >&2
    exit 1
  fi
  quoted_args="$(join_shell_args "$@")"
  if [ "$subcommand" = "capture" ]; then
    nix \
      "${NIX_ARGS[@]}" \
      --extra-experimental-features "nix-command flakes" \
      develop "path:$REPO_ROOT#default" \
      --command env \
        DIALTONE_NIX_ACTIVE=1 \
        DIALTONE_NIX_SHELL="default" \
        DIALTONE_HOST_PATH="$PATH" \
        DIALTONE_REPO_ROOT="$REPO_ROOT" \
        DIALTONE_STATE_DIR="$DIALTONE_STATE_DIR" \
        DIALTONE_STATE_DB="$DIALTONE_STATE_DB" \
        DIALTONE_NIX_OFFLINE="${DIALTONE_NIX_OFFLINE:-0}" \
        DIALTONE_USE_NIX="$USE_NIX" \
        zsh -lc "cd $(shell_quote "$REPO_ROOT/src") && \${DIALTONE_GO_BIN:-go} run ./mods.go $quoted_args"
    return
  fi
  exec nix \
    "${NIX_ARGS[@]}" \
    --extra-experimental-features "nix-command flakes" \
    develop "path:$REPO_ROOT#default" \
    --command env \
      DIALTONE_NIX_ACTIVE=1 \
      DIALTONE_NIX_SHELL="default" \
      DIALTONE_HOST_PATH="$PATH" \
      DIALTONE_REPO_ROOT="$REPO_ROOT" \
      DIALTONE_STATE_DIR="$DIALTONE_STATE_DIR" \
      DIALTONE_STATE_DB="$DIALTONE_STATE_DB" \
      DIALTONE_NIX_OFFLINE="${DIALTONE_NIX_OFFLINE:-0}" \
      DIALTONE_USE_NIX="$USE_NIX" \
      zsh -lc "cd $(shell_quote "$REPO_ROOT/src") && exec \${DIALTONE_GO_BIN:-go} run ./mods.go $quoted_args"
}

if [ ! -f "$REPO_ROOT/src/mods.go" ]; then
  echo "DIALTONE> src/mods.go not found under $REPO_ROOT" >&2
  exit 1
fi

if [ ! -d "$REPO_ROOT/src/mods" ]; then
  echo "DIALTONE> src/mods not found under $REPO_ROOT" >&2
  exit 1
fi

hydrate_env_from_state_db
REPO_ROOT="${DIALTONE_REPO_ROOT:-$REPO_ROOT}"
USE_NIX="${DIALTONE_USE_NIX:-$USE_NIX}"
DIALTONE_HOME_ROOT="${HOME:-$REPO_ROOT}"
DIALTONE_STATE_DIR="${DIALTONE_STATE_DIR:-$DIALTONE_HOME_ROOT/.dialtone}"
DIALTONE_STATE_DB="${DIALTONE_STATE_DB:-$DIALTONE_STATE_DIR/state.sqlite}"
DIALTONE_BIN_DIR="${DIALTONE_BIN_DIR:-$DIALTONE_STATE_DIR/bin}"
DIALTONE_TMUX_TARGET_FILE="${DIALTONE_TMUX_TARGET_FILE:-$DIALTONE_STATE_DIR/tmux_target}"
NIXPKGS_FLAKE_REF="${DIALTONE_NIXPKGS_FLAKE:-${NIXPKGS_FLAKE:-nixpkgs}}"
mkdir -p "$DIALTONE_STATE_DIR"

if [ "${1:-}" = "__dialtone" ]; then
  shift || true
  exec_dialtone_internal "$@"
fi

ensure_bootstrap_state

if [ "${1:-}" = "dialtone" ] && [ "${2:-}" = "v1" ]; then
  case "${3:-}" in
    ""|ensure|serve|status|state|bootstrap|queue|paths|processes|commands|command|log|logs|protocol-runs|protocol-run|test-runs|test-run)
      shift 2 || true
      exec_dialtone_internal "$@"
      ;;
  esac
fi

if [ "${1:-}" = "shell" ] && [ "${2:-}" = "v1" ]; then
  case "${3:-}" in
    state|status)
      if parse_fast_shell_status_args "${@:4}"; then
        exec_dialtone_internal status "${@:4}"
      fi
      ;;
  esac
fi

if [ "$#" -ge 2 ] && should_route_via_shell "${1:-}" "${2:-}" "${3:-}"; then
  if ! should_execute_direct_in_pane_fast "$@"; then
    exec_dialtone_internal queue "$@"
  fi
fi

add_nix_package() {
  local pkg="$1"
  if [ -z "$pkg" ]; then
    return
  fi
  pkg="$(rewrite_nix_package_ref "$pkg")"
  local existing=""
  for existing in "${DIALTONE_NIX_PACKAGES[@]:-}"; do
    if [ "$existing" = "$pkg" ]; then
      return
    fi
  done
  DIALTONE_NIX_PACKAGES+=("$pkg")
}

join_nix_package_sig() {
  local out=""
  local pkg=""
  for pkg in "${DIALTONE_NIX_PACKAGES[@]:-}"; do
    if [ -n "$out" ]; then
      out="${out},"
    fi
    out="${out}${pkg}"
  done
  printf '%s' "$out"
}

add_nix_package "nixpkgs#bashInteractive"
add_nix_package "nixpkgs#git"
add_nix_package "nixpkgs#go_1_25"
FLAKE_SHELL=""
while IFS=$'\t' read -r plan_kind plan_value; do
  case "$plan_kind" in
    "flake_shell")
      FLAKE_SHELL="$plan_value"
      ;;
    "package")
      add_nix_package "$plan_value"
      ;;
  esac
done < <(
  run_go_in_default_nix capture __nix-plan "${1:-}" "${2:-}" 2>/dev/null || true
)
NIX_PACKAGE_SIG="$(join_nix_package_sig)"

if [ "$USE_NIX" != "0" ] && [ -n "$FLAKE_SHELL" ] && [ "${DIALTONE_NIX_ACTIVE:-0}" != "1" ]; then
  if ! command -v nix >/dev/null 2>&1; then
    echo "DIALTONE> nix is required for dialtone_mod (set DIALTONE_USE_NIX=0 to bypass)" >&2
    exit 1
  fi
  declare -a NIX_ARGS=()
  if [ "${DIALTONE_NIX_OFFLINE:-0}" = "1" ]; then
    NIX_ARGS+=(--offline)
  fi
  exec nix \
    "${NIX_ARGS[@]}" \
    --extra-experimental-features "nix-command flakes" \
    develop "path:$REPO_ROOT#$FLAKE_SHELL" \
    --command env \
      DIALTONE_NIX_ACTIVE=1 \
      DIALTONE_NIX_SHELL="$FLAKE_SHELL" \
      DIALTONE_HOST_PATH="$PATH" \
      DIALTONE_REPO_ROOT="$REPO_ROOT" \
      DIALTONE_STATE_DIR="$DIALTONE_STATE_DIR" \
      DIALTONE_STATE_DB="$DIALTONE_STATE_DB" \
      DIALTONE_NIX_OFFLINE="${DIALTONE_NIX_OFFLINE:-0}" \
      DIALTONE_USE_NIX="$USE_NIX" \
      "$REPO_ROOT/dialtone_mod" "$@"
fi

if [ "$USE_NIX" != "0" ] && [ -z "$FLAKE_SHELL" ] && [ "${DIALTONE_NIX_ACTIVE:-0}" != "1" ]; then
  if ! command -v nix >/dev/null 2>&1; then
    echo "DIALTONE> nix is required for dialtone_mod (set DIALTONE_USE_NIX=0 to bypass)" >&2
    exit 1
  fi
  declare -a NIX_ARGS=()
  if [ "${DIALTONE_NIX_OFFLINE:-0}" = "1" ]; then
    NIX_ARGS+=(--offline)
  fi
  exec nix \
    "${NIX_ARGS[@]}" \
    --extra-experimental-features "nix-command flakes" \
    shell \
    "${DIALTONE_NIX_PACKAGES[@]}" \
    --command env \
      DIALTONE_NIX_ACTIVE=1 \
      DIALTONE_NIX_PACKAGES_SIG="$NIX_PACKAGE_SIG" \
      DIALTONE_NIXPKGS_FLAKE="$NIXPKGS_FLAKE_REF" \
      NIXPKGS_FLAKE="$NIXPKGS_FLAKE_REF" \
      DIALTONE_HOST_PATH="$PATH" \
      DIALTONE_REPO_ROOT="$REPO_ROOT" \
      DIALTONE_STATE_DIR="$DIALTONE_STATE_DIR" \
      DIALTONE_STATE_DB="$DIALTONE_STATE_DB" \
      DIALTONE_NIX_OFFLINE="${DIALTONE_NIX_OFFLINE:-0}" \
      DIALTONE_USE_NIX="$USE_NIX" \
      "$REPO_ROOT/dialtone_mod" "$@"
fi

cd "$REPO_ROOT/src"
exec "${DIALTONE_GO_BIN:-go}" run ./mods.go "$@"
