#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="${DIALTONE_REPO_ROOT:-$SCRIPT_DIR}"
USE_NIX="${DIALTONE_USE_NIX:-1}"
NIXPKGS_FLAKE_REF="${DIALTONE_NIXPKGS_FLAKE:-${NIXPKGS_FLAKE:-nixpkgs}}"
DIALTONE_TMUX_TARGET_FILE="$REPO_ROOT/.dialtone/tmux_target"
declare -a DIALTONE_NIX_PACKAGES=()

rewrite_nix_package_ref() {
  local pkg="${1:-}"
  if [[ "$pkg" == nixpkgs#* ]] && [ "$NIXPKGS_FLAKE_REF" != "nixpkgs" ]; then
    printf '%s#%s' "$NIXPKGS_FLAKE_REF" "${pkg#nixpkgs#}"
    return
  fi
  printf '%s' "$pkg"
}

resolve_flake_shell() {
  local mod="${1:-}"
  local version="${2:-}"
  case "${mod}:${version}" in
    "repl:v1")
      printf '%s' "repl-v1"
      ;;
    "ssh:v1")
      printf '%s' "ssh-v1"
      ;;
    *)
      printf '%s' ""
      ;;
  esac
}

shell_quote() {
  printf "%q" "${1:-}"
}

join_shell_args() {
  local out=""
  local arg=""
  for arg in "$@"; do
    if [ -n "$out" ]; then
      out+=" "
    fi
    out+="$(shell_quote "$arg")"
  done
  printf '%s' "$out"
}

load_tmux_target() {
  local raw=""
  if [ -n "${DIALTONE_TMUX_TARGET:-}" ]; then
    printf '%s' "${DIALTONE_TMUX_TARGET}"
    return
  fi
  if [ -f "$DIALTONE_TMUX_TARGET_FILE" ]; then
    IFS= read -r raw < "$DIALTONE_TMUX_TARGET_FILE" || true
    printf '%s' "$(printf '%s' "$raw" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    return
  fi
  printf '%s' ""
}

tmux_target_ref() {
  local raw="${1:-}"
  local session=""
  local window=""
  local pane=""
  IFS=':' read -r session window pane <<< "$raw"
  if [ -n "$session" ] && [ -n "$window" ] && [ -n "$pane" ]; then
    printf '%s:%s.%s' "$session" "$window" "$pane"
    return
  fi
  printf '%s' "$raw"
}

should_bypass_tmux_proxy() {
  local mod="${1:-}"
  local version="${2:-}"
  case "${mod}:${version}" in
    "tmux:v1"|"ghostty:v1")
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

if [ ! -f "$REPO_ROOT/src/mods.go" ]; then
  echo "DIALTONE> src/mods.go not found under $REPO_ROOT" >&2
  exit 1
fi

if [ ! -d "$REPO_ROOT/src/mods" ]; then
  echo "DIALTONE> src/mods not found under $REPO_ROOT" >&2
  exit 1
fi

add_nix_package() {
  local pkg="$1"
  if [ -z "$pkg" ]; then
    return
  fi
  pkg="$(rewrite_nix_package_ref "$pkg")"
  local existing=""
  for existing in "${DIALTONE_NIX_PACKAGES[@]:-}"; do
    if [ "$existing" = "$pkg" ]; then
      return
    fi
  done
  DIALTONE_NIX_PACKAGES+=("$pkg")
}

load_mod_nix_packages() {
  local mod="${1:-}"
  local version="${2:-}"
  local manifest=""
  local raw=""
  local selector=""
  local pkg=""

  add_nix_package "nixpkgs#bashInteractive"
  add_nix_package "nixpkgs#git"
  add_nix_package "nixpkgs#go_1_24"

  if [ -z "$mod" ] || [ -z "$version" ]; then
    return
  fi

  manifest="$REPO_ROOT/src/mods/$mod/$version/nix.packages"
  if [ ! -f "$manifest" ]; then
    return
  fi

  while true; do
    if ! IFS= read -r raw; then
      break
    fi
    raw="$(printf '%s' "$raw" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    if [ -z "$raw" ]; then
      continue
    fi
    if [[ "$raw" == \#* ]]; then
      continue
    fi

    selector=""
    pkg="$raw"
    if [[ "$raw" == *:* ]]; then
      selector="${raw%%:*}"
      pkg="${raw#*:}"
      pkg="$(printf '%s' "$pkg" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
    fi

    case "$selector" in
      ""|"all")
        add_nix_package "$pkg"
        ;;
      "linux")
        [ "$(uname -s)" = "Linux" ] && add_nix_package "$pkg"
        ;;
      "darwin")
        [ "$(uname -s)" = "Darwin" ] && add_nix_package "$pkg"
        ;;
    esac
  done < "$manifest"
}

join_nix_package_sig() {
  local out=""
  local pkg=""
  for pkg in "${DIALTONE_NIX_PACKAGES[@]:-}"; do
    if [ -n "$out" ]; then
      out="${out},"
    fi
    out="${out}${pkg}"
  done
  printf '%s' "$out"
}

load_mod_nix_packages "${1:-}" "${2:-}"
NIX_PACKAGE_SIG="$(join_nix_package_sig)"
FLAKE_SHELL="$(resolve_flake_shell "${1:-}" "${2:-}")"
TMUX_TARGET="$(load_tmux_target)"

if [ -n "$TMUX_TARGET" ] && [ "${DIALTONE_TMUX_PROXY_ACTIVE:-0}" != "1" ] && ! should_bypass_tmux_proxy "${1:-}" "${2:-}"; then
  if ! command -v tmux >/dev/null 2>&1; then
    echo "DIALTONE> tmux is required for tmux target proxying" >&2
    exit 1
  fi
  TMUX_TARGET_REF="$(tmux_target_ref "$TMUX_TARGET")"
  TMUX_COMMAND="DIALTONE_TMUX_PROXY_ACTIVE=1 $(shell_quote "$REPO_ROOT/dialtone_mod")"
  if [ "$#" -gt 0 ]; then
    TMUX_COMMAND+=" $(join_shell_args "$@")"
  fi
  tmux send-keys -t "$TMUX_TARGET_REF" C-c >/dev/null 2>&1 || true
  tmux send-keys -t "$TMUX_TARGET_REF" -- "$TMUX_COMMAND"
  tmux send-keys -t "$TMUX_TARGET_REF" C-m
  echo "DIALTONE> sent to tmux target $TMUX_TARGET: $*"
  exit 0
fi

if [ "$USE_NIX" != "0" ] && [ -n "$FLAKE_SHELL" ] && { [ "${DIALTONE_NIX_ACTIVE:-0}" != "1" ] || [ "${DIALTONE_NIX_SHELL:-}" != "$FLAKE_SHELL" ]; }; then
  if ! command -v nix >/dev/null 2>&1; then
    echo "DIALTONE> nix is required for dialtone_mod (set DIALTONE_USE_NIX=0 to bypass)" >&2
    exit 1
  fi
  NIX_ARGS=()
  if [ "${DIALTONE_NIX_OFFLINE:-0}" = "1" ]; then
    NIX_ARGS+=(--offline)
  fi
  exec nix \
    "${NIX_ARGS[@]}" \
    --extra-experimental-features "nix-command flakes" \
    develop "path:$REPO_ROOT#$FLAKE_SHELL" \
    --command env \
      DIALTONE_NIX_ACTIVE=1 \
      DIALTONE_NIX_SHELL="$FLAKE_SHELL" \
      DIALTONE_REPO_ROOT="$REPO_ROOT" \
      DIALTONE_NIX_OFFLINE="${DIALTONE_NIX_OFFLINE:-0}" \
      DIALTONE_USE_NIX="$USE_NIX" \
      "$REPO_ROOT/dialtone_mod" "$@"
fi

if [ "$USE_NIX" != "0" ] && [ -z "$FLAKE_SHELL" ] && { [ "${DIALTONE_NIX_ACTIVE:-0}" != "1" ] || [ "${DIALTONE_NIX_PACKAGES_SIG:-}" != "$NIX_PACKAGE_SIG" ]; }; then
  if ! command -v nix >/dev/null 2>&1; then
    echo "DIALTONE> nix is required for dialtone_mod (set DIALTONE_USE_NIX=0 to bypass)" >&2
    exit 1
  fi
  NIX_ARGS=()
  if [ "${DIALTONE_NIX_OFFLINE:-0}" = "1" ]; then
    NIX_ARGS+=(--offline)
  fi
  exec nix \
    "${NIX_ARGS[@]}" \
    --extra-experimental-features "nix-command flakes" \
    shell \
    "${DIALTONE_NIX_PACKAGES[@]}" \
    --command env \
      DIALTONE_NIX_ACTIVE=1 \
      DIALTONE_NIX_PACKAGES_SIG="$NIX_PACKAGE_SIG" \
      DIALTONE_NIXPKGS_FLAKE="$NIXPKGS_FLAKE_REF" \
      NIXPKGS_FLAKE="$NIXPKGS_FLAKE_REF" \
      DIALTONE_REPO_ROOT="$REPO_ROOT" \
      DIALTONE_NIX_OFFLINE="${DIALTONE_NIX_OFFLINE:-0}" \
      DIALTONE_USE_NIX="$USE_NIX" \
      "$REPO_ROOT/dialtone_mod" "$@"
fi

cd "$REPO_ROOT"
exec "${DIALTONE_GO_BIN:-go}" run ./src/mods.go "$@"
