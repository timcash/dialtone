  fi
  if [ -n "$worker_last_status" ]; then
    printf 'worker_last_status\t%s\n' "$worker_last_status"
  fi
  if [ -n "$worker_last_exit_code" ]; then
    printf 'worker_last_exit_code\t%s\n' "$worker_last_exit_code"
  fi
  if [ -n "$worker_last_summary" ]; then
    printf 'worker_last_summary\t%s\n' "$worker_last_summary"
  fi
  printf 'dialtone_processes_running\t%d\n' "$process_count"
  printf 'dialtone_processes_background\t%d\n' "$background_count"
  printf 'dialtone_mod_running\t%d\n' "$client_process_count"
  printf 'dialtone_mod_background\t%d\n' "$client_background_count"
  printf 'dialtone_running\t%d\n' "$daemon_process_count"
  printf 'worker_running\t%d\n' "$worker_process_count"
  printf 'ensure_running\t%d\n' "$ensure_process_count"
  printf 'inspect\t./dialtone_mod shell v1 status --row-id %s --full --sync=false\n' "$row_id"
  printf '\n'
  printf '%-8s %-8s %-6s %-6s %-12s %-10s %s\n' "PID" "PPID" "STAT" "TTY" "ROLE" "BACKGROUND" "COMMAND"
  if [ -n "$process_rows" ]; then
    while IFS=$'\t' read -r pid ppid stat tty role background command; do
      [ -n "$pid" ] || continue
      printf '%-8s %-8s %-6s %-6s %-12s %-10s %s\n' "$pid" "$ppid" "$stat" "$tty" "$role" "$background" "$command"
    done <<<"$process_rows"
  fi
}

route_via_shell_fast() {
