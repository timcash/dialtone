{
  "DIALTONE_HOME": "~/.dialtone",
  "DIALTONE_ENV": "~/.dialtone_env",
  "DIALTONE_GO_CACHE_DIR": "~/.dialtone_env/cache/go",
  "DIALTONE_BUN_CACHE_DIR": "~/.dialtone_env/cache/bun",
  "DIALTONE_TOOL_CACHE_DIR": "~/.dialtone_env/cache/tools",
  "DIALTONE_CONTAINER_CACHE_DIR": "~/.dialtone_env/cache/containers",
  "DIALTONE_WSL_BUILD_IMAGE": "dialtone-builder-alpine:go1.25.5",
  "DIALTONE_ZIG_VERSION": "0.13.0",
  "GH_TOKEN": "",
  "DIALTONE_REPO_ROOT": "/home/user/dialtone",
  "DIALTONE_USE_NIX": "0",
  "DIALTONE_CHROME_SRC_V3_ACTIONS_PER_SECOND": "5.0",
  "DIALTONE_CHROME_SRC_V3_INTERACTION_COUNT": "6",
  "DIALTONE_CHROME_SRC_V3_HEADLESS": "0",
  "camera_src_v1_install": {
    "tools": [
      {
        "name": "go",
        "version": "1.25.5",
        "manager": "dialtone"
      },
      {
        "name": "zig",
        "version": "0.13.0",
        "manager": "dialtone"
      }
    ]
  },
  "robot_src_v2_install": {
    "depends_on": [
      "camera src_v1",
      "github src_v1",
      "bun src_v1"
    ]
  },
  "mesh_nodes": [
    {
      "name": "wsl",
      "aliases": [
        "wsl"
      ],
      "user": "user",
      "host": "wsl.shad-artichoke.ts.net",
      "host_candidates": [
        "wsl.shad-artichoke.ts.net"
      ],
      "route_preference": [
        "tailscale",
        "private"
      ],
      "port": "22",
      "os": "linux",
      "repo_candidates": [
        "/home/user/dialtone"
      ]
    },
    {
      "name": "legion",
      "aliases": [
        "legion",
        "windows"
      ],
      "user": "timca",
      "host": "legion",
      "host_candidates": [
        "legion"
      ],
      "route_preference": [
        "private"
      ],
      "port": "22",
      "os": "windows",
      "prefer_wsl_powershell": true,
      "repo_candidates": [
        "C:\\Users\\timca\\dialtone",
        "/mnt/c/Users/timca/dialtone"
      ]
    }
  ]
}
